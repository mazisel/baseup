# ============================================================
#  Ortam değişkenleri örneği — bu dosyayı .env.local'e kopyalayıp doldurun.
#  cp .env.example .env.local
#  (NODE_ENV ve NEXT_RUNTIME Next.js tarafından otomatik ayarlanır, eklemeyin.)
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # RLS bypass — yalnızca sunucuda, ASLA public değil

# ---- Uygulama URL'leri ----
# Uygulamanın herkese açık adresi. PayTR dönüş (ok/fail) URL'leri ve e-posta
# linkleri bunu kullanır. PRODUCTION'da gerçek domain olmalı (localhost DEĞİL).
NEXT_PUBLIC_SITE_URL=https://alan-adiniz.com
NEXT_PUBLIC_APP_URL=https://alan-adiniz.com

# ---- PayTR (ödeme) ----
# PayTR Mağaza Paneli > "Bilgi" / "Mağaza Bilgileri" bölümünden alınır.
# ÜÇÜ DE ZORUNLU; eksikse kod "test_merchant_*" sahte değerlerine düşer ve ödeme başlamaz.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# ---- Redis (iş kuyruğu / worker) ----
REDIS_HOST=localhost
REDIS_PORT=6379
# Worker'ın farklı hesaplar için aynı anda işleyeceği iş sayısı (varsayılan 10)
WORKER_CONCURRENCY=10

# ---- E-posta (Resend) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NEXT_PUBLIC_FROM_EMAIL=

# ---- Runner / diğer ----
# dry-run = güvenli simülasyon (varsayılan) | legacy = gerçek migration çalıştırır
SAAS_RUNNER_MODE=dry-run
LEGACY_WEBAPP_URL=
ADMIN_EMAILS=                        # virgülle ayrılmış admin e-postaları
