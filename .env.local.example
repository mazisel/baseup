NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth/DB. The app runs in demo-cookie mode without these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Runner mode. Use dry-run for safe SaaS UX, or legacy to bridge to the existing webapp server.
SAAS_RUNNER_MODE=dry-run
LEGACY_WEBAPP_URL=http://localhost:4567
